# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication
# Create these in your Clerk dashboard for this project.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# PostgreSQL database
# Neon, Supabase, Railway, or a local PostgreSQL URL will work.
DATABASE_URL=

# Stream video
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=

# OpenAI
OPENAI_API_KEY=

# Inngest background jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Polar billing, optional until premium checkout is wired up
POLAR_ACCESS_TOKEN=
POLAR_ENVIRONMENT=sandbox
